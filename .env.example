# Apify API Token — get yours at https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# Google Gemini API Key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Turso (SQLite in the cloud) — get yours at https://turso.tech
TURSO_CONNECTION_URL=libsql://your-db-name-xxx.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
# Netlify Functions - Owner/Client email routing
OWNER_EMAIL=owner@yourdomain.com
EMAIL_PROVIDER=resend
OWNER_EMAIL_PROVIDER=smtp

# Resend (primary)
RESEND_API_KEY=re_your_resend_api_key
# Use your verified sender/domain on Resend.
# Temporary testing option only: Brand Name <onboarding@resend.dev>
# Recommended production sender: Brand Name <quotes@yourdomain.com>
RESEND_FROM_EMAIL=Brand Name <quotes@yourdomain.com>

# Optional SMTP fallback
FROM_EMAIL=Brand Name <quotes@yourdomain.com>
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=quotes@yourdomain.com
SMTP_PASS=your_smtp_password

# Optional Google Sheets webhook
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-web-app-id/exec
GOOGLE_SHEETS_WEBHOOK_SECRET=your_shared_secret
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/your-sheet-id/edit
GOOGLE_SHEET_ID=your-sheet-id
GOOGLE_SHEET_TAB=Leads
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token

# Frontend analytics
# Add GA4 Measurement ID (G-XXXXXXXXXX) in site-config.js under analytics.ga4MeasurementId

# Optional abuse-control tuning
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=6
